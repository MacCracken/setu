# programs/client_test.cyr — RUN test for the setu client transport.
#
# The socket ops (connect/listen/accept/send/recv) need a live compositor peer —
# they are proven end-to-end by the puka <-> aethersafha integration over TCP
# loopback (item 3b). Here we assert the pure/linkable surface: the well-known
# transport port + a framed round-trip through the codec the client sends/reads,
# so the client module links and its framing is sound. Exit code = failed checks
# (0 = PASS), matching the setu codec_test / sadish RUN-test convention.

include "src/lib.cyr"

var g_fails = 0;
fn check(got, want): i64 {
    if (got == want) { return 0; }
    g_fails = g_fails + 1;
    return 1;
}

fn main(): i64 {
    # The setu channel is a well-known loopback TCP port (the 3b transport).
    check(SETU_TCP_PORT, 7700);

    # A framed round-trip through the client's send/read shape: build a
    # CREATE_SURFACE, encode it into a frame buffer, decode it back, and assert
    # the surface dims survive the LE-i64 wire.
    var m = setu_create_surface(320, 200, 0);
    var buf = alloc(128);
    var enc = setu_encode(m, buf, 128);
    check(enc > 0, 1);
    var out = setu_msg_new();
    var dec = setu_decode(buf, enc, out);
    check(dec > 0, 1);
    check(setu_msg_kind(out), SETU_CREATE_SURFACE);
    check(setu_msg_arg(out, 0), 320);
    check(setu_msg_arg(out, 1), 200);

    if (g_fails == 0) {
        var ok = "client_test: PASS (transport port + framed create-surface round-trip)\n";
        syscall(SYS_WRITE, 1, ok, strlen(ok));
    } else {
        var f = "client_test: FAIL\n";
        syscall(SYS_WRITE, 2, f, strlen(f));
    }
    return g_fails;
}

fn _entry(): i64 { var r = main(); syscall(SYS_EXIT, r); return 0; }
_entry();
